# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=ai_commerce

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional: switch chat LLM to Groq (Llama 3.3 70B). Falls back to Ollama if empty.
# Embeddings always use Ollama (nomic-embed-text).
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# ChromaDB (local persistent)
CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION=products

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Clerk (verify JWTs from frontend)
CLERK_JWT_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_JWKS_URL=https://your-tenant.clerk.accounts.dev/.well-known/jwks.json

# CORS
FRONTEND_ORIGIN=http://localhost:3000

# Server
APP_ENV=development
LOG_LEVEL=info
